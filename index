<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Why Diving Matters</title>
    <style>
        /* RESET & BASE */
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #1e3a5f;
            --secondary: #00bcd4;
            --accent: #ff6b9d;
            --bg: #f8f9fa;
            --text: #333333;
            --card-bg: #ffffff;
            --shadow: 0 4px 20px rgba(0,0,0,0.08);
            --shadow-hover: 0 12px 40px rgba(0,0,0,0.15);
        }
        html { scroll-behavior: smooth; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* NAVBAR */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background: rgba(30, 58, 95, 0.95);
            backdrop-filter: blur(10px);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.3s ease;
        }
        .navbar.scrolled { background: rgba(30, 58, 95, 0.98); box-shadow: 0 2px 20px rgba(0,0,0,0.3); }
        .nav-brand { color: #fff; font-size: 1.4rem; font-weight: 700; letter-spacing: -0.5px; }
        .nav-links { display: flex; gap: 2rem; list-style: none; }
        .nav-links a { color: rgba(255,255,255,0.85); text-decoration: none; font-weight: 500; transition: color 0.3s; font-size: 0.95rem; }
        .nav-links a:hover { color: var(--secondary); }

        /* HERO */
        .hero {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: linear-gradient(135deg, #0a1628 0%, #1e3a5f 30%, #0e4d6e 60%, #00838f 100%);
            position: relative;
            overflow: hidden;
            padding: 6rem 2rem 4rem;
        }
        .hero::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(ellipse at 50% 80%, rgba(0,188,212,0.15) 0%, transparent 60%);
            pointer-events: none;
        }
        .hero-content { position: relative; z-index: 2; max-width: 900px; }
        .hero h1 {
            font-size: clamp(2.5rem, 6vw, 4.5rem);
            color: #fff;
            font-weight: 800;
            margin-bottom: 1rem;
            letter-spacing: -1px;
            animation: fadeInDown 1s ease;
        }
        .hero p {
            font-size: clamp(1.1rem, 2.5vw, 1.5rem);
            color: rgba(255,255,255,0.8);
            margin-bottom: 2.5rem;
            animation: fadeInUp 1s ease 0.3s both;
        }
        .hero-image {
            width: 100%;
            max-width: 900px;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4);
            animation: fadeInUp 1s ease 0.5s both;
        }
        .hero-image img { width: 100%; height: auto; display: block; }
        .hero-cta {
            display: inline-block;
            margin-top: 2.5rem;
            padding: 1rem 2.5rem;
            background: var(--secondary);
            color: #fff;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            animation: fadeInUp 1s ease 0.7s both;
        }
        .hero-cta:hover { background: #00a5bb; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,188,212,0.4); }

        /* SECTIONS */
        section { padding: 6rem 2rem; }
        .section-header {
            text-align: center;
            max-width: 700px;
            margin: 0 auto 4rem;
        }
        .section-header h2 {
            font-size: clamp(2rem, 4vw, 3rem);
            color: var(--primary);
            font-weight: 800;
            margin-bottom: 1rem;
            letter-spacing: -0.5px;
        }
        .section-header p { font-size: 1.15rem; color: #666; }
        .section-header .accent-line {
            width: 60px;
            height: 4px;
            background: linear-gradient(90deg, var(--secondary), var(--accent));
            margin: 1.5rem auto 0;
            border-radius: 2px;
        }

        /* CARD GRID */
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 2.5rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        .card {
            background: var(--card-bg);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            opacity: 0;
            transform: translateY(40px);
        }
        .card.visible { opacity: 1; transform: translateY(0); }
        .card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: var(--shadow-hover);
        }
        .card-image {
            width: 100%;
            height: 280px;
            overflow: hidden;
            position: relative;
        }
        .card-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }
        .card:hover .card-image img { transform: scale(1.08); }
        .card-image::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 60px;
            background: linear-gradient(transparent, rgba(0,0,0,0.05));
            pointer-events: none;
        }
        .card-body { padding: 1.8rem; }
        .card-body h3 {
            font-size: 1.3rem;
            color: var(--primary);
            margin-bottom: 0.8rem;
            font-weight: 700;
        }
        .card-body p { color: #555; font-size: 0.95rem; line-height: 1.7; }

        /* BENEFITS SECTION */
        .benefits-section { background: linear-gradient(180deg, #f0f8ff 0%, var(--bg) 100%); }
        .benefit-card .card-body h3 .emoji { margin-right: 0.5rem; font-size: 1.4rem; }

        /* STATS SECTION */
        .stats-section {
            background: linear-gradient(135deg, var(--primary) 0%, #0e4d6e 100%);
            padding: 5rem 2rem;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            max-width: 1000px;
            margin: 0 auto;
            text-align: center;
        }
        .stat-item { color: #fff; }
        .stat-number {
            font-size: 3.5rem;
            font-weight: 800;
            color: var(--secondary);
            margin-bottom: 0.5rem;
        }
        .stat-label { font-size: 1rem; opacity: 0.85; font-weight: 500; }

        /* CTA BANNER */
        .cta-section {
            background: linear-gradient(135deg, #00838f 0%, var(--secondary) 50%, #0097a7 100%);
            text-align: center;
            padding: 5rem 2rem;
        }
        .cta-section h2 { color: #fff; font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 1rem; font-weight: 800; }
        .cta-section p { color: rgba(255,255,255,0.9); font-size: 1.2rem; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto; }
        .cta-btn {
            display: inline-block;
            padding: 1rem 3rem;
            background: #fff;
            color: var(--primary);
            text-decoration: none;
            border-radius: 50px;
            font-weight: 700;
            font-size: 1.1rem;
            transition: all 0.3s ease;
        }
        .cta-btn:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,0,0,0.2); }

        /* FOOTER */
        .footer {
            background: #0a1628;
            color: rgba(255,255,255,0.7);
            padding: 3rem 2rem;
            text-align: center;
        }
        .footer-content { max-width: 800px; margin: 0 auto; }
        .footer h3 { color: #fff; font-size: 1.5rem; margin-bottom: 1rem; }
        .footer p { margin-bottom: 0.5rem; font-size: 0.9rem; }
        .footer-links { display: flex; justify-content: center; gap: 2rem; margin-top: 1.5rem; flex-wrap: wrap; }
        .footer-links a { color: var(--secondary); text-decoration: none; font-weight: 500; transition: color 0.3s; }
        .footer-links a:hover { color: #fff; }

        /* ANIMATIONS */
        @keyframes fadeInDown { from { opacity: 0; transform: translateY(-30px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }
        .shimmer {
            position: relative;
            overflow: hidden;
        }
        .shimmer::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
            background-size: 200% 100%;
            animation: shimmer 3s infinite;
            pointer-events: none;
        }

        /* ===== AQUATIC ATHLETE CHALLENGE GAME ===== */
        .game-section {
            background: linear-gradient(180deg, #e3f2fd 0%, #b3e5fc 50%, #e1f5fe 100%);
            padding: 5rem 2rem;
            position: relative;
            overflow: hidden;
        }
        .game-section::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background:
                radial-gradient(ellipse at 20% 80%, rgba(0,188,212,0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(30,58,95,0.06) 0%, transparent 50%);
            pointer-events: none;
        }
        .game-section .section-header h2 { color: var(--primary); }

        .game-container {
            max-width: 900px;
            margin: 0 auto;
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 8px 40px rgba(30,58,95,0.12);
            overflow: hidden;
            position: relative;
        }

        /* Pool Canvas Area */
        .pool-area {
            position: relative;
            width: 100%;
            height: 200px;
            background: linear-gradient(180deg, #0288d1 0%, #01579b 40%, #002f6c 100%);
            overflow: hidden;
        }
        .pool-area canvas { display: block; width: 100%; height: 100%; }

        /* HUD - Heads Up Display */
        .game-hud {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1px;
            background: #e0e0e0;
        }
        .hud-item {
            background: #fff;
            padding: 1rem;
            text-align: center;
        }
        .hud-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #888;
            font-weight: 600;
        }
        .hud-value {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--primary);
            margin-top: 0.25rem;
        }
        .hud-value.score-val { color: var(--secondary); }
        .hud-value.timer-val { color: #e65100; }

        /* Underwater distance bar */
        .uw-bar-wrap {
            padding: 1rem 1.5rem;
            background: #fafafa;
            border-bottom: 1px solid #eee;
        }
        .uw-bar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.5rem;
        }
        .uw-bar-label { font-size: 0.85rem; font-weight: 700; color: var(--primary); }
        .uw-bar-dist { font-size: 0.85rem; font-weight: 700; color: #555; }
        .uw-bar-track {
            width: 100%;
            height: 14px;
            background: #e0e0e0;
            border-radius: 7px;
            overflow: hidden;
            position: relative;
        }
        .uw-bar-fill {
            height: 100%;
            border-radius: 7px;
            transition: width 0.4s ease, background 0.4s ease;
            width: 0%;
            background: #4caf50;
        }
        .uw-bar-fill.warning { background: linear-gradient(90deg, #4caf50, #ffc107); }
        .uw-bar-fill.danger { background: linear-gradient(90deg, #ffc107, #f44336); }
        .uw-bar-mark {
            position: absolute;
            top: -2px;
            bottom: -2px;
            width: 2px;
            background: rgba(0,0,0,0.3);
        }
        .uw-bar-mark span {
            position: absolute;
            top: -16px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.6rem;
            color: #999;
            white-space: nowrap;
        }

        /* Event notification */
        .game-event {
            padding: 0.8rem 1.5rem;
            background: #e8f5e9;
            border-left: 4px solid #4caf50;
            font-size: 0.9rem;
            color: #2e7d32;
            font-weight: 500;
            min-height: 42px;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
        }
        .game-event.warn { background: #fff3e0; border-left-color: #ff9800; color: #e65100; }
        .game-event.danger { background: #ffebee; border-left-color: #f44336; color: #c62828; }
        .game-event.info { background: #e3f2fd; border-left-color: #2196f3; color: #1565c0; }
        .game-event.gold { background: #fff8e1; border-left-color: #ffd600; color: #f57f17; }

        /* Controls area */
        .game-controls {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }
        .ctrl-row {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            justify-content: center;
        }
        .game-btn {
            padding: 0.8rem 1.8rem;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.25s ease;
            font-family: inherit;
            position: relative;
            overflow: hidden;
        }
        .game-btn:active { transform: scale(0.96); }
        .game-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
        .game-btn.primary {
            background: linear-gradient(135deg, var(--secondary), #0097a7);
            color: #fff;
            box-shadow: 0 4px 15px rgba(0,188,212,0.3);
        }
        .game-btn.primary:hover:not(:disabled) { box-shadow: 0 6px 20px rgba(0,188,212,0.5); transform: translateY(-2px); }
        .game-btn.surface {
            background: linear-gradient(135deg, #ff6b9d, #e91e63);
            color: #fff;
            box-shadow: 0 4px 15px rgba(255,107,157,0.3);
            animation: pulse-surface 1.2s ease-in-out infinite;
        }
        .game-btn.surface:hover:not(:disabled) { box-shadow: 0 6px 20px rgba(255,107,157,0.5); }
        @keyframes pulse-surface {
            0%, 100% { box-shadow: 0 4px 15px rgba(255,107,157,0.3); }
            50% { box-shadow: 0 4px 25px rgba(255,107,157,0.6); }
        }
        .game-btn.speed { background: linear-gradient(135deg, #f44336, #d32f2f); color: #fff; }
        .game-btn.speed:hover:not(:disabled) { box-shadow: 0 4px 15px rgba(244,67,54,0.4); transform: translateY(-2px); }
        .game-btn.control { background: linear-gradient(135deg, #ff9800, #f57c00); color: #fff; }
        .game-btn.control:hover:not(:disabled) { box-shadow: 0 4px 15px rgba(255,152,0,0.4); transform: translateY(-2px); }
        .game-btn.cautious { background: linear-gradient(135deg, #4caf50, #388e3c); color: #fff; }
        .game-btn.cautious:hover:not(:disabled) { box-shadow: 0 4px 15px rgba(76,175,80,0.4); transform: translateY(-2px); }
        .game-btn.reset {
            background: transparent;
            color: #888;
            border: 2px solid #ddd;
        }
        .game-btn.reset:hover:not(:disabled) { border-color: #aaa; color: #555; }
        .stroke-info { font-size: 0.7rem; display: block; opacity: 0.85; margin-top: 2px; }

        /* Difficulty selector */
        .difficulty-select {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            justify-content: center;
        }
        .diff-btn {
            padding: 0.5rem 1.2rem;
            border: 2px solid #ddd;
            border-radius: 8px;
            background: #fff;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all 0.2s;
            font-family: inherit;
        }
        .diff-btn:hover { border-color: var(--secondary); }
        .diff-btn.active { border-color: var(--secondary); background: var(--secondary); color: #fff; }

        /* Game info sidebar (desktop) */
        .game-info-panel {
            padding: 1.5rem;
            border-top: 1px solid #eee;
            background: #fafafa;
        }
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }
        .info-box {
            background: #fff;
            border-radius: 10px;
            padding: 1rem;
            border: 1px solid #eee;
        }
        .info-box h4 {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--secondary);
            margin-bottom: 0.5rem;
        }
        .info-box p, .info-box ul { font-size: 0.85rem; color: #555; }
        .info-box ul { padding-left: 1.2rem; }
        .info-box li { margin-bottom: 0.25rem; }

        /* Game overlay (win/lose screens) */
        .game-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.75);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 10;
            backdrop-filter: blur(4px);
        }
        .game-overlay.active { display: flex; }
        .overlay-card {
            background: #fff;
            border-radius: 20px;
            padding: 2.5rem;
            text-align: center;
            max-width: 400px;
            width: 90%;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            animation: popIn 0.4s ease;
        }
        @keyframes popIn {
            from { transform: scale(0.8); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
        .overlay-card h3 { font-size: 1.8rem; margin-bottom: 0.5rem; }
        .overlay-card .result-icon { font-size: 4rem; margin-bottom: 1rem; display: block; }
        .overlay-card .result-stats { margin: 1rem 0; text-align: left; }
        .overlay-card .result-stats div {
            display: flex;
            justify-content: space-between;
            padding: 0.4rem 0;
            border-bottom: 1px solid #eee;
            font-size: 0.9rem;
        }
        .overlay-card .result-stats span:last-child { font-weight: 700; color: var(--primary); }
        .overlay-btns { display: flex; gap: 0.75rem; margin-top: 1.5rem; justify-content: center; flex-wrap: wrap; }

        /* Achievements */
        .achievements { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; margin-top: 1rem; }
        .badge {
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            background: #e8f5e9;
            color: #2e7d32;
            border: 1px solid #c8e6c9;
        }
        .badge.gold { background: #fff8e1; color: #f57f17; border-color: #ffecb3; }
        .badge.blue { background: #e3f2fd; color: #1565c0; border-color: #bbdefb; }

        /* Best score bar */
        .best-score-bar {
            display: flex;
            justify-content: center;
            gap: 2rem;
            padding: 0.8rem;
            background: linear-gradient(90deg, rgba(30,58,95,0.05), rgba(0,188,212,0.08), rgba(30,58,95,0.05));
            font-size: 0.8rem;
            color: #666;
        }
        .best-score-bar strong { color: var(--primary); }

        /* Keyboard hint */
        .kb-hint {
            font-size: 0.75rem;
            color: #aaa;
            text-align: center;
            padding-bottom: 0.5rem;
        }
        .kb-hint kbd {
            background: #eee;
            padding: 0.15rem 0.4rem;
            border-radius: 3px;
            font-family: inherit;
            font-size: 0.7rem;
            border: 1px solid #ddd;
        }

        @media (max-width: 768px) {
            .game-hud { grid-template-columns: repeat(2, 1fr); }
            .pool-area { height: 150px; }
            .info-grid { grid-template-columns: 1fr; }
            .game-btn { padding: 0.7rem 1.2rem; font-size: 0.85rem; }
            .overlay-card { padding: 1.5rem; }
        }
        @media (max-width: 480px) {
            .game-hud { grid-template-columns: repeat(2, 1fr); }
            .hud-value { font-size: 1.2rem; }
        }

        /* MOBILE NAV */
        .nav-toggle { display: none; background: none; border: none; cursor: pointer; padding: 0.5rem; }
        .nav-toggle span { display: block; width: 25px; height: 3px; background: #fff; margin: 5px 0; border-radius: 2px; transition: all 0.3s; }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .nav-links { display: none; flex-direction: column; position: absolute; top: 100%; left: 0; right: 0; background: rgba(30,58,95,0.98); padding: 1rem 2rem; gap: 1rem; }
            .nav-links.active { display: flex; }
            .nav-toggle { display: block; }
            .card-grid { grid-template-columns: 1fr; gap: 1.5rem; }
            .card-image { height: 220px; }
            section { padding: 4rem 1.5rem; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .stat-number { font-size: 2.5rem; }
        }
        @media (max-width: 480px) {
            .stats-grid { grid-template-columns: 1fr; }
            .hero { padding: 5rem 1.5rem 3rem; }
        }
    </style>
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="nav-brand">Why Diving Matters</div>
        <button class="nav-toggle" aria-label="Toggle navigation">
            <span></span><span></span><span></span>
        </button>
        <ul class="nav-links">
            <li><a href="#hero">Home</a></li>
            <li><a href="#why-diving">Why It Matters</a></li>
            <li><a href="#benefits">Benefits</a></li>
            <li><a href="#game-section">Game</a></li>
            <li><a href="#stats">Impact</a></li>
            <li><a href="#cta">Get Started</a></li>
        </ul>
    </nav>

    <!-- HERO SECTION -->
    <section class="hero" id="hero">
        <div class="hero-content">
            <h1>Why Diving Matters</h1>
            <p>Discover the Beauty, Strength, and Artistry of Diving</p>
            <div class="hero-image shimmer">
