    <script>
        // Navbar scroll effect
        const navbar = document.querySelector('.navbar');
        window.addEventListener('scroll', () => {
            navbar.classList.toggle('scrolled', window.scrollY > 50);
        });

        // Mobile nav toggle
        const navToggle = document.querySelector('.nav-toggle');
        const navLinks = document.querySelector('.nav-links');
        navToggle.addEventListener('click', () => {
            navLinks.classList.toggle('active');
        });
        navLinks.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => navLinks.classList.remove('active'));
        });

        // Intersection Observer for card animations
        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry, index) => {
                if (entry.isIntersecting) {
                    setTimeout(() => {
                        entry.target.classList.add('visible');
                    }, index * 100);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        document.querySelectorAll('.card').forEach(card => observer.observe(card));

        // Counter animation for stats
        const counterObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const counters = entry.target.querySelectorAll('.stat-number');
                    counters.forEach(counter => {
                        const target = parseInt(counter.dataset.target);
                        const duration = 2000;
                        const start = performance.now();
                        const animate = (now) => {
                            const elapsed = now - start;
                            const progress = Math.min(elapsed / duration, 1);
                            const eased = 1 - Math.pow(1 - progress, 3);
                            counter.textContent = Math.round(target * eased);
                            if (progress < 1) requestAnimationFrame(animate);
                            else counter.textContent = target;
                        };
                        requestAnimationFrame(animate);
                    });
                    counterObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.3 });

        counterObserver.observe(document.querySelector('.stats-grid'));

        // ===== AQUATIC ATHLETE CHALLENGE GAME =====
        (function() {
            // --- State ---
            const DIFFICULTIES = {
                1: { name: 'Beginner', distance: 100, lives: 3 },
                2: { name: 'Intermediate', distance: 150, lives: 2 },
                3: { name: 'Expert', distance: 200, lives: 1 }
            };
            const FACTS = [
                'World Aquatics enforces a 15-meter maximum underwater limit per swim.',
                'Olympic pools must be 3.0 meters deep for optimal competition.',
                'Minimum pool depth for major events is 2.0 meters.',
                'Wave turbulence affects swimming speed \u2014 deeper pools are faster.',
                'Breaststroke athletes can take one pull and one kick while submerged.',
                'Proper breathing technique is crucial for speed and endurance.',
                'Elite swimmers average 35+ km/h when entering water.',
                'Training focus: muscle memory for the 15-meter turn.',
                'Fatigue management is key to competitive swimming.',
                'Perfect form in freestyle can add 2\u20133 meters per stroke.'
            ];
            const EVENTS = [
                { text: 'Wave Turbulence Alert! Slight speed reduction.', type: 'warn', effect: 'slow' },
                { text: 'Perfect Form! Speed boost + bonus points!', type: 'gold', effect: 'boost' },
                { text: 'Muscle Fatigue! Reduced stroke distance next turn.', type: 'warn', effect: 'fatigue' },
                { text: 'Pool Depth: 2.5m optimal! Faster swimming!', type: 'info', effect: 'boost' },
                { text: 'Breaststroke Exception Applied \u2014 special rule!', type: 'info', effect: 'none' },
                { text: 'Crowd Cheer! Motivation boost!', type: 'gold', effect: 'boost' },
                { text: 'Coach Tip: Breathing technique is crucial!', type: 'info', effect: 'none' }
            ];
            let state = {
                phase: 'idle', // idle, diving, underwater, surfaced, over
                difficulty: 1,
                totalDist: 100,
                distance: 0,
                uwDist: 0,
                score: 0,
                lives: 3,
                timer: 0,
                timerInterval: null,
                uwInterval: null,
                fatigued: false,
                boosted: false,
                perfectSurfaces: 0,
                strokesTaken: 0,
                bestScore: parseInt(localStorage.getItem('aac_best') || '0'),
                gamesPlayed: parseInt(localStorage.getItem('aac_games') || '0'),
                gamesWon: parseInt(localStorage.getItem('aac_wins') || '0')
            };

            // --- DOM refs ---
            const $ = id => document.getElementById(id);
            const hudDist = $('hudDist'), hudScore = $('hudScore'), hudTime = $('hudTime'), hudStatus = $('hudStatus');
            const uwBarFill = $('uwBarFill'), uwDistLabel = $('uwDistLabel');
            const gameEvent = $('gameEvent');
            const btnStart = $('btnStart'), btnReset = $('btnReset'), btnSurface = $('btnSurface');
            const surfaceRow = $('surfaceRow'), strokeRow = $('strokeRow'), mainBtns = $('mainBtns'), diffSelect = $('diffSelect');
            const gameOverlay = $('gameOverlay'), overlayCard = $('overlayCard');
            const bestScoreVal = $('bestScoreVal'), gamesPlayedEl = $('gamesPlayed'), winRateEl = $('winRate');
            const canvas = $('poolCanvas');
            const ctx = canvas.getContext('2d');

            // --- Canvas setup ---
            let animFrame;
            let swimmer = { x: 40, y: 0, targetX: 40, underwater: false };
            function resizeCanvas() {
                const rect = canvas.parentElement.getBoundingClientRect();
                canvas.width = rect.width * 2;
                canvas.height = rect.height * 2;
                ctx.scale(1, 1);
            }
            resizeCanvas();
            window.addEventListener('resize', resizeCanvas);

            // Wave particles
            let waves = [];
            for (let i = 0; i < 30; i++) {
                waves.push({ x: Math.random() * 2000, y: Math.random() * 400, r: 2 + Math.random() * 4, speed: 0.3 + Math.random() * 0.8, alpha: 0.1 + Math.random() * 0.3 });
            }

            function drawPool() {
                const w = canvas.width, h = canvas.height;
                ctx.clearRect(0, 0, w, h);
                // Water gradient
                const grd = ctx.createLinearGradient(0, 0, 0, h);
                grd.addColorStop(0, '#0288d1');
                grd.addColorStop(0.5, '#01579b');
                grd.addColorStop(1, '#002f6c');
                ctx.fillStyle = grd;
                ctx.fillRect(0, 0, w, h);

                // Lane lines
                ctx.strokeStyle = 'rgba(255,255,255,0.08)';
                ctx.lineWidth = 2;
                for (let i = 1; i < 6; i++) {
                    const y = (h / 6) * i;
                    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(w, y); ctx.stroke();
                }

                // Distance markers
                if (state.totalDist > 0) {
                    ctx.fillStyle = 'rgba(255,255,255,0.15)';
                    ctx.font = '18px sans-serif';
                    ctx.textAlign = 'center';
                    for (let m = 25; m < state.totalDist; m += 25) {
                        const px = 40 + (m / state.totalDist) * (w - 80);
                        ctx.fillText(m + 'm', px, 22);
                        ctx.beginPath();
                        ctx.setLineDash([4, 6]);
                        ctx.moveTo(px, 28); ctx.lineTo(px, h);
                        ctx.stroke();
                        ctx.setLineDash([]);
                    }
                    // Finish line
                    ctx.strokeStyle = 'rgba(255,215,0,0.5)';
                    ctx.lineWidth = 3;
                    const fx = w - 40;
                    ctx.beginPath(); ctx.moveTo(fx, 0); ctx.lineTo(fx, h); ctx.stroke();
                    ctx.fillStyle = 'rgba(255,215,0,0.7)';
                    ctx.font = 'bold 20px sans-serif';
                    ctx.fillText('FINISH', fx, h - 12);
                }

                // Wave particles
                waves.forEach(p => {
                    p.x += p.speed;
                    if (p.x > w + 10) p.x = -10;
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(255,255,255,${p.alpha})`;
                    ctx.fill();
                });

                // Swimmer
                const sy = swimmer.underwater ? h * 0.65 : h * 0.35;
                swimmer.y += (sy - swimmer.y) * 0.08;
                swimmer.x += (swimmer.targetX - swimmer.x) * 0.06;
                drawSwimmer(swimmer.x, swimmer.y, swimmer.underwater);

                // Bubbles when underwater
                if (swimmer.underwater && Math.random() < 0.3) {
                    waves.push({ x: swimmer.x + Math.random() * 20 - 10, y: swimmer.y - 5, r: 1 + Math.random() * 3, speed: -0.1, alpha: 0.4 });
                }

                animFrame = requestAnimationFrame(drawPool);
            }

            function drawSwimmer(x, y, uw) {
                ctx.save();
                // Body
                ctx.fillStyle = uw ? '#ffcc80' : '#ffe0b2';
                ctx.beginPath();
                ctx.ellipse(x, y, 22, 10, 0, 0, Math.PI * 2);
                ctx.fill();
                // Head
                ctx.beginPath();
                ctx.arc(x + 24, y - 2, 9, 0, Math.PI * 2);
                ctx.fill();
                // Cap
                ctx.fillStyle = 'var(--secondary)';
                ctx.fillStyle = '#00bcd4';
                ctx.beginPath();
                ctx.arc(x + 24, y - 5, 8, Math.PI, 0);
                ctx.fill();
                // Arms (animated)
                const armAngle = (Date.now() / 200) % (Math.PI * 2);
                ctx.strokeStyle = '#ffcc80';
                ctx.lineWidth = 4;
                ctx.lineCap = 'round';
                // Left arm
                ctx.beginPath();
                ctx.moveTo(x + 10, y);
                ctx.lineTo(x + 10 + Math.cos(armAngle) * 16, y + Math.sin(armAngle) * 16);
                ctx.stroke();
                // Right arm
                ctx.beginPath();
                ctx.moveTo(x - 5, y);
                ctx.lineTo(x - 5 + Math.cos(armAngle + Math.PI) * 16, y + Math.sin(armAngle + Math.PI) * 16);
                ctx.stroke();
                // Legs
                const legAngle = (Date.now() / 250) % (Math.PI * 2);
                ctx.beginPath();
                ctx.moveTo(x - 20, y + 3);
                ctx.lineTo(x - 32 + Math.sin(legAngle) * 6, y + 8);
                ctx.stroke();
                ctx.beginPath();
                ctx.moveTo(x - 20, y - 3);
                ctx.lineTo(x - 32 + Math.sin(legAngle + Math.PI) * 6, y - 8);
                ctx.stroke();
                ctx.restore();
            }

            drawPool();

            // --- UI Helpers ---
            function updateHUD() {
                hudDist.textContent = state.distance + ' / ' + state.totalDist + ' m';
                hudScore.textContent = state.score;
                hudStatus.textContent = state.phase === 'idle' ? 'Ready' :
                    state.phase === 'underwater' ? 'Underwater' :
                    state.phase === 'surfaced' ? 'Swimming' :
                    state.phase === 'diving' ? 'Diving...' :
                    state.phase === 'over' ? 'Finished' : state.phase;
                updateBest();
            }
            function updateUWBar() {
                const pct = Math.min((state.uwDist / 15) * 100, 100);
                uwBarFill.style.width = pct + '%';
                uwBarFill.className = 'uw-bar-fill' + (state.uwDist > 13 ? ' danger' : state.uwDist > 10 ? ' warning' : '');
                uwDistLabel.textContent = state.uwDist.toFixed(1) + ' / 15 m';
            }
            function setEvent(text, type) {
                gameEvent.textContent = text;
                gameEvent.className = 'game-event ' + (type || 'info');
            }
            function updateBest() {
                bestScoreVal.textContent = state.bestScore > 0 ? state.bestScore : '--';
                gamesPlayedEl.textContent = state.gamesPlayed;
                winRateEl.textContent = state.gamesPlayed > 0 ? Math.round((state.gamesWon / state.gamesPlayed) * 100) + '%' : '--';
            }
            function showControls(set) {
                surfaceRow.style.display = set === 'surface' ? 'flex' : 'none';
                strokeRow.style.display = set === 'stroke' ? 'flex' : 'none';
                mainBtns.style.display = set === 'main' ? 'flex' : 'none';
                diffSelect.style.display = set === 'main' ? 'flex' : 'none';
            }
            function swimmerPos() {
                const w = canvas.width;
                swimmer.targetX = 40 + (state.distance / state.totalDist) * (w - 80);
            }

            // --- Timer ---
            function startTimer() {
                state.timer = 0;
                state.timerInterval = setInterval(() => {
                    state.timer += 0.1;
                    hudTime.textContent = state.timer.toFixed(1) + 's';
                }, 100);
            }
            function stopTimer() {
                clearInterval(state.timerInterval);
            }

            // --- Underwater phase ---
            function startUnderwater() {
                state.phase = 'underwater';
                state.uwDist = 0;
                swimmer.underwater = true;
                updateHUD();
                showControls('surface');
                setEvent('You are underwater! Surface before 15m!', 'warn');
                state.uwInterval = setInterval(() => {
                    state.uwDist += 0.5;
                    state.distance = Math.min(state.distance + 0.5, state.totalDist);
                    state.score += 1;
                    swimmerPos();
                    updateUWBar();
                    updateHUD();
                    if (state.uwDist >= 15) {
                        clearInterval(state.uwInterval);
                        disqualify();
                    }
                    if (state.distance >= state.totalDist) {
                        clearInterval(state.uwInterval);
                        victory();
                    }
                }, 300);
            }

            // --- Surface ---
            function doSurface() {
                if (state.phase !== 'underwater') return;
                clearInterval(state.uwInterval);
                swimmer.underwater = false;
                state.phase = 'surfaced';
                if (state.uwDist <= 10) {
                    state.score += 15;
                    state.perfectSurfaces++;
                    setEvent('Perfect surface at ' + state.uwDist.toFixed(1) + 'm! +15 bonus points!', 'gold');
                } else {
                    setEvent('Surfaced at ' + state.uwDist.toFixed(1) + 'm. Choose your stroke!', 'info');
                }
                state.uwDist = 0;
                updateUWBar();
                updateHUD();
                if (state.distance >= state.totalDist) { victory(); return; }
                showControls('stroke');
            }

            // --- Strokes ---
            function doStroke(type) {
                if (state.phase !== 'surfaced') return;
                state.strokesTaken++;
                let baseDist = type === 'speed' ? 5 : type === 'control' ? 3 : 2;
                let bonus = 0;

                // Fatigue / boost modifiers
                if (state.fatigued) { baseDist = Math.max(1, baseDist - 1); state.fatigued = false; }
                if (state.boosted) { baseDist += 1; bonus += 5; state.boosted = false; }

                // Risk for speed stroke
                if (type === 'speed' && Math.random() < 0.25) {
                    baseDist = Math.max(1, baseDist - 2);
                    setEvent('Risky stroke! Lost control \u2014 only ' + baseDist + 'm gained.', 'warn');
                } else {
                    bonus += type === 'speed' ? 3 : type === 'control' ? 5 : 8;
                }

                state.distance = Math.min(state.distance + baseDist, state.totalDist);
                state.score += baseDist + bonus;
                swimmerPos();
                updateHUD();

                if (state.distance >= state.totalDist) { victory(); return; }

                // Random event
                if (Math.random() < 0.45) {
                    const evt = EVENTS[Math.floor(Math.random() * EVENTS.length)];
                    setEvent(evt.text, evt.type);
                    if (evt.effect === 'fatigue') state.fatigued = true;
                    if (evt.effect === 'boost') { state.boosted = true; state.score += 5; }
                    if (evt.effect === 'slow') { /* next underwater will be slightly slower */ }
                } else {
                    const fact = FACTS[Math.floor(Math.random() * FACTS.length)];
                    setEvent(fact, 'info');
                }

                // Go back underwater
                setTimeout(() => {
                    if (state.phase === 'surfaced' || state.phase === 'over') {
                        if (state.phase !== 'over') startUnderwater();
                    }
                }, 1200);
                showControls(null);
            }

            // --- End conditions ---
            function disqualify() {
                state.phase = 'over';
                state.lives--;
                stopTimer();
                swimmer.underwater = false;
                showControls(null);
                state.gamesPlayed++;
                localStorage.setItem('aac_games', state.gamesPlayed);
                updateBest();

                let html = '<span class="result-icon">&#x1F6AB;</span>';
                html += '<h3 style="color:#c62828">DISQUALIFIED!</h3>';
                html += '<p style="color:#666;margin-bottom:1rem">You violated the 15-meter underwater rule!</p>';
                html += '<div class="result-stats">';
                html += '<div><span>Distance</span><span>' + Math.round(state.distance) + ' / ' + state.totalDist + ' m</span></div>';
                html += '<div><span>Time</span><span>' + state.timer.toFixed(1) + 's</span></div>';
                html += '<div><span>Score</span><span>' + state.score + '</span></div>';
                html += '</div>';
                html += '<div class="overlay-btns">';
                html += '<button class="game-btn primary" onclick="window._gameReset()">TRY AGAIN</button>';
                html += '</div>';
                overlayCard.innerHTML = html;
                gameOverlay.classList.add('active');
            }

            function victory() {
                state.phase = 'over';
                stopTimer();
                swimmer.underwater = false;
                showControls(null);

                // Bonuses
                const timeBonus = Math.max(0, Math.round(300 - state.timer * 2));
                const techBonus = state.perfectSurfaces * 10;
                const ruleBonus = 50;
                state.score += timeBonus + techBonus + ruleBonus;
                state.gamesPlayed++;
                state.gamesWon++;
                if (state.score > state.bestScore) {
                    state.bestScore = state.score;
                    localStorage.setItem('aac_best', state.bestScore);
                }
                localStorage.setItem('aac_games', state.gamesPlayed);
                localStorage.setItem('aac_wins', state.gamesWon);
                updateBest();

                // Ranking
                const pace = state.timer;
                let rank = pace < 30 ? 'World Record Pace!' : pace < 60 ? 'Gold Medal!' : pace < 90 ? 'Silver Medal!' : 'Bronze Medal!';

                // Achievements
                let badges = [];
                if (state.perfectSurfaces >= 3) badges.push({ t: 'Perfect Surfacer', c: 'gold' });
                if (state.strokesTaken <= state.totalDist / 4) badges.push({ t: 'Efficient Swimmer', c: 'blue' });
                if (state.timer < 45) badges.push({ t: 'Speed Demon', c: 'gold' });
                badges.push({ t: 'Rule Expert', c: '' });
                if (state.difficulty === 3) badges.push({ t: 'Expert Champion', c: 'gold' });

                let html = '<span class="result-icon">&#x1F3C6;</span>';
                html += '<h3 style="color:#1e3a5f">VICTORY! ' + rank + '</h3>';
                html += '<div class="result-stats">';
                html += '<div><span>Distance</span><span>' + state.totalDist + ' m</span></div>';
                html += '<div><span>Time</span><span>' + state.timer.toFixed(1) + 's</span></div>';
                html += '<div><span>Time Bonus</span><span>+' + timeBonus + '</span></div>';
                html += '<div><span>Technique Bonus</span><span>+' + techBonus + '</span></div>';
                html += '<div><span>Rule Compliance</span><span>+' + ruleBonus + '</span></div>';
                html += '<div><span><strong>Total Score</strong></span><span><strong>' + state.score + '</strong></span></div>';
                html += '</div>';
                if (badges.length) {
                    html += '<div class="achievements">';
                    badges.forEach(b => { html += '<span class="badge ' + b.c + '">' + b.t + '</span>'; });
                    html += '</div>';
                }
                html += '<div class="overlay-btns">';
                if (state.difficulty < 3) html += '<button class="game-btn primary" onclick="window._gameNextDiff()">HARDER DIFFICULTY</button>';
                html += '<button class="game-btn reset" onclick="window._gameReset()">PLAY AGAIN</button>';
                html += '</div>';
                overlayCard.innerHTML = html;
                gameOverlay.classList.add('active');
            }

            // --- Start / Reset ---
            function startGame() {
                const diff = DIFFICULTIES[state.difficulty];
                state.phase = 'diving';
                state.totalDist = diff.distance;
                state.lives = diff.lives;
                state.distance = 0;
                state.uwDist = 0;
                state.score = 0;
                state.fatigued = false;
                state.boosted = false;
                state.perfectSurfaces = 0;
                state.strokesTaken = 0;
                swimmer.x = 40;
                swimmer.targetX = 40;
                swimmer.underwater = true;
                updateHUD();
                updateUWBar();
                gameOverlay.classList.remove('active');
                btnStart.disabled = true;
                btnReset.disabled = false;
                setEvent('Diving in... Get ready to surface before 15m!', 'info');
                showControls(null);
                startTimer();
                setTimeout(() => startUnderwater(), 1000);
            }

            function resetGame() {
                state.phase = 'idle';
                clearInterval(state.uwInterval);
                stopTimer();
                state.distance = 0;
                state.uwDist = 0;
                state.score = 0;
                state.timer = 0;
                swimmer.x = 40;
                swimmer.targetX = 40;
                swimmer.underwater = false;
                hudTime.textContent = '0.0s';
                updateHUD();
                updateUWBar();
                gameOverlay.classList.remove('active');
                btnStart.disabled = false;
                btnReset.disabled = true;
                showControls('main');
                setEvent('Select difficulty and press START RACE to begin!', 'info');
            }

            // --- Event Listeners ---
            btnStart.addEventListener('click', startGame);
            btnReset.addEventListener('click', resetGame);
            btnSurface.addEventListener('click', doSurface);
            window._gameReset = resetGame;
            window._gameNextDiff = function() {
                if (state.difficulty < 3) {
                    state.difficulty++;
                    document.querySelectorAll('.diff-btn').forEach(b => b.classList.toggle('active', parseInt(b.dataset.level) === state.difficulty));
                }
                resetGame();
                setTimeout(startGame, 300);
            };

            // Difficulty buttons
            document.querySelectorAll('.diff-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    if (state.phase !== 'idle') return;
                    state.difficulty = parseInt(this.dataset.level);
                    document.querySelectorAll('.diff-btn').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    const diff = DIFFICULTIES[state.difficulty];
                    state.totalDist = diff.distance;
                    updateHUD();
                });
            });

            // Stroke buttons
            document.querySelectorAll('[data-stroke]').forEach(btn => {
                btn.addEventListener('click', function() { doStroke(this.dataset.stroke); });
            });

            // Keyboard controls
            document.addEventListener('keydown', function(e) {
                if (e.key === ' ' || e.code === 'Space') { e.preventDefault(); doSurface(); }
                if (e.key === '1') doStroke('speed');
                if (e.key === '2') doStroke('control');
                if (e.key === '3') doStroke('cautious');
                if (e.key === 'r' || e.key === 'R') resetGame();
            });

            updateBest();
            updateHUD();
        })();
    </script>
</body>
</html>
